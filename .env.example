# NVIDIA — AI demo on the home page (free, OpenAI-compatible, rate-limited)
# Get a free key at https://build.nvidia.com
NVIDIA_API_KEY=nvapi-YOUR_KEY_HERE
# Optional model override (default: meta/llama-3.3-70b-instruct)
# NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# Resend — contact form email delivery
# Get your key at https://resend.com — free tier is fine for low volume
RESEND_API_KEY=re_YOUR_KEY_HERE

# Where contact form submissions are sent
CONTACT_TO_EMAIL=ucaisoc@outlook.com

# Resend "From" address — must be a verified domain in your Resend account
# For local testing you can use: onboarding@resend.dev
CONTACT_FROM_EMAIL=noreply@ucaisoc.nz
